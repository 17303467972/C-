<Window x:Class="SerialPortApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:SerialPortApp"
        mc:Ignorable="d"
        Title="Serial Port Monitor" Height="720" Width="1024"
        Closed="Window_Closed">
    <Window.Resources>
        <local:LogLevelColorConverter x:Key="LogLevelColorConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 串口配置区域 -->
        <GroupBox Header="串口配置" Margin="5">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cmbPorts" Width="200" Margin="5" 
                        DisplayMemberPath="Description"/>
                <ComboBox x:Name="cmbBaudRate" Width="100" Margin="5" SelectedIndex="0">
                    <ComboBoxItem>9600</ComboBoxItem>
                    <ComboBoxItem>19200</ComboBoxItem>
                    <ComboBoxItem>115200</ComboBoxItem>
                </ComboBox>
                <Button x:Name="btnOpen" Content="打开端口" Width="80" Margin="5" Click="BtnOpen_Click"/>
                <Button x:Name="btnRefresh" Content="刷新端口" Width="80" Margin="5" Click="RefreshPorts"/>
                <CheckBox x:Name="chkHexView" Content="HEX显示" Margin="5" VerticalAlignment="Center"/>
                <Button Content="测试数据" Width="80" Margin="5" Click="BtnTest_Click"/>
                <TextBlock Margin="10" VerticalAlignment="Center">
                    <Run Text="阈值:"/><TextBox x:Name="txtThreshold" Width="40" Text="80"/>
                </TextBlock>
            </StackPanel>
        </GroupBox>

        <!-- 数据展示区域 -->
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="实时曲线">
                <Grid>
                    <oxy:PlotView x:Name="plotView" Model="{Binding PlotModel}">
                        <oxy:PlotView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="重置视图" Click="ResetView_Click"/>
                                <MenuItem Header="导出图片" Click="ExportImage_Click"/>
                            </ContextMenu>
                        </oxy:PlotView.ContextMenu>
                    </oxy:PlotView>
                    <TextBlock x:Name="tbChartStatus" Margin="10" HorizontalAlignment="Right" 
                             VerticalAlignment="Top" Background="#AAFFFFFF"/>
                </Grid>
            </TabItem>
            <TabItem Header="原始数据">
                <TextBox x:Name="txtRawData" IsReadOnly="True" 
                       VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            </TabItem>
        </TabControl>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="2" Header="系统日志" Margin="5">
            <DataGrid x:Name="dgLogs" AutoGenerateColumns="False" IsReadOnly="True"
                    ItemsSource="{Binding LogEntries}" LoadingRow="DgLogs_LoadingRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" Width="120" Binding="{Binding Timestamp}"/>
                    <DataGridTextColumn Header="信息" Width="*" Binding="{Binding Message}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="级别" Width="80" Binding="{Binding Level}">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" 
                                      Value="{Binding Level, Converter={StaticResource LogLevelColorConverter}}"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>